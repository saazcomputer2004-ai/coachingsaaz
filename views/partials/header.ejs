<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Saaz Project</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
    margin:0;
    padding:0;
    font-family:Arial, sans-serif;
}

.navbar{
    background: linear-gradient(135deg, #2f6ea9, #223f5f);
    padding:16px 0;
}

.navbar-brand{
    font-size:32px;
    font-weight:800;
    color:#ffffff !important;
    letter-spacing:1px;
}

.brand-text{
    color:#00e5ff;
}

.nav-link{
    color:#ffffff !important;
    font-size:17px;
    font-weight:600;
    margin:0 10px;
    position:relative;
    transition:0.3s;
}

.nav-link::after{
    content:"";
    position:absolute;
    left:0;
    bottom:-8px;
    width:0%;
    height:3px;
    border-radius:10px;
    background:linear-gradient(90deg,#00e5ff,#00ff88);
    transition:0.3s;
}

.nav-link:hover::after,
.nav-link.active::after{
    width:100%;
}

.nav-link:hover,
.nav-link.active{
    color:#00e5ff !important;
}

.login-btn{
    background:linear-gradient(135deg,#00e5ff,#007bff);
    color:#fff !important;
    border-radius:50px;
    padding:11px 28px !important;
    margin-left:15px;
    font-weight:700;
    box-shadow:0 8px 20px rgba(0,123,255,0.35);
    transition:0.3s;
}

.login-btn:hover{
    transform:translateY(-3px) scale(1.03);
    background:linear-gradient(135deg,#00c6ff,#0056ff);
}

/* ── Toggler Button ── */
.navbar-toggler{
    border: 2px solid rgba(0,229,255,0.5);
    background: transparent;
    padding: 8px 11px;
    border-radius: 8px;
    cursor: pointer;
    transition: border-color 0.2s;
}

.navbar-toggler:hover{
    border-color: #00e5ff;
}

/* ── Animated 3 bars icon ── */
.toggler-icon{
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 22px;
}

.toggler-icon span{
    display: block;
    height: 2px;
    background: #00e5ff;
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
}

/* X shape when open */
.navbar-toggler.open .toggler-icon span:nth-child(1){
    transform: translateY(7px) rotate(45deg);
}

.navbar-toggler.open .toggler-icon span:nth-child(2){
    opacity: 0;
}

.navbar-toggler.open .toggler-icon span:nth-child(3){
    transform: translateY(-7px) rotate(-45deg);
}

/* ── Mobile Menu ── */
#mainMenu{
    display: none;
}

#mainMenu.open{
    display: block;
}

@media(min-width: 992px){
    #mainMenu{
        display: flex !important;
    }
    .navbar-toggler{
        display: none;
    }
}

@media(max-width: 991px){
    .nav-link{
        margin: 12px 0;
        text-align: center;
        display: block;
    }
    .navbar-collapse{
        background: rgba(255,255,255,0.03);
        padding: 20px;
        border-radius: 18px;
        margin-top: 15px;
    }
}
</style>

</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark sticky-top">
<div class="container d-flex align-items-center justify-content-between">

    <a class="navbar-brand" href="/">Saaz Group of Education</a>

    <!-- Toggle Button -->
    <button class="navbar-toggler" id="menuToggler" type="button">
        <div class="toggler-icon">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </button>

    <!-- Menu -->
    <div id="mainMenu" class="navbar-collapse">
        <ul class="navbar-nav ms-auto align-items-lg-center">
            <li class="nav-item"><a class="nav-link" href="#home">Home</a></li>
            <li class="nav-item"><a class="nav-link" href="#director">About</a></li>
            <li class="nav-item"><a class="nav-link" href="#courses">Courses</a></li>
            <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
        </ul>
    </div>

</div>
</nav>

<script>
    const toggler = document.getElementById('menuToggler');
    const menu = document.getElementById('mainMenu');

    toggler.addEventListener('click', function () {
        toggler.classList.toggle('open');
        menu.classList.toggle('open');
    });

    
</script>

</body>
</html>