<%- include("partials/header") %>

<style>
:root {
  --red: #e63312;
  --dark: #1a1a2e;
  --gold: #f5a623;
  --light-bg: #f8f9fa;
}



/* HERO */
.hero-section-new {
  background: linear-gradient(135deg, var(--dark) 0%, #16213e 60%, #0f3460 100%);
  min-height: 88vh;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
}
.hero-section-new::before {
  content: '';
  position: absolute;
  top: -50%; right: -10%;
  width: 650px; height: 650px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(230,51,18,.18) 0%, transparent 70%);
}
.hero-section-new::after {
  content: '';
  position: absolute;
  bottom: -20%; left: -5%;
  width: 400px; height: 400px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(245,166,35,.12) 0%, transparent 70%);
}
.hero-badge {
  background: rgba(230,51,18,.2);
  border: 1px solid rgba(230,51,18,.5);
  color: var(--red);
  font-weight: 700;
  font-size: .8rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  padding: 6px 18px;
  border-radius: 50px;
  display: inline-block;
  margin-bottom: 20px;
}
.hero-section-new h1 {
  color: #fff;
  font-size: 3.5rem;
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 16px;
}
.hero-section-new h1 span { color: var(--gold); }
.hero-section-new .hero-lead {
  color: rgba(255,255,255,.75);
  font-size: 1.1rem;
  max-width: 520px;
  margin-bottom: 32px;
}
.btn-hero {
  background: var(--red);
  color: #fff;
  font-weight: 700;
  padding: 14px 32px;
  border-radius: 50px;
  border: none;
  font-size: 1rem;
  margin-right: 12px;
  text-decoration: none;
  display: inline-block;
  transition: all .3s;
}
.btn-hero:hover { background: #c72a0e; color: #fff; transform: translateY(-2px); }
.btn-hero-outline {
  background: transparent;
  color: #fff;
  border: 2px solid rgba(255,255,255,.4);
  font-weight: 700;
  padding: 14px 32px;
  border-radius: 50px;
  font-size: 1rem;
  text-decoration: none;
  display: inline-block;
  transition: all .3s;
}
.btn-hero-outline:hover { border-color: #fff; color: #fff; }
.hero-stats { display: flex; gap: 40px; margin-top: 48px; flex-wrap: wrap; }
.stat-num { color: var(--gold); font-size: 2rem; font-weight: 800; }
.stat-label { color: rgba(255,255,255,.6); font-size: .8rem; text-transform: uppercase; letter-spacing: 1px; }
.hero-card {
  background: rgba(255,255,255,.07);
  backdrop-filter: blur(14px);
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 20px;
  padding: 28px;
  color: #fff;
}
.hero-card h4 { font-weight: 700; margin-bottom: 16px; font-size: 1.1rem; }
.course-pill {
  background: rgba(230,51,18,.2);
  border: 1px solid rgba(230,51,18,.4);
  color: #ff9f9a;
  font-size: .78rem;
  padding: 5px 14px;
  border-radius: 50px;
  display: inline-block;
  margin: 4px;
  font-weight: 600;
}
.cert-badges { display: flex; gap: 10px; margin-top: 18px; flex-wrap: wrap; }
.cert-badge {
  background: rgba(245,166,35,.15);
  border: 1px solid rgba(245,166,35,.4);
  color: var(--gold);
  font-size: .75rem;
  padding: 5px 12px;
  border-radius: 8px;
  font-weight: 700;
}

/* SECTION COMMON */
.section-title { text-align: center; margin-bottom: 50px; }
.section-label {
  color: var(--red);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  font-size: .85rem;
}
.section-title h2 { font-size: 2.4rem; font-weight: 800; margin-top: 8px; }
.section-title p { color: #666; max-width: 580px; margin: 12px auto 0; }

/* FEATURES */
.features-dark {background: linear-gradient(135deg, #357abf, #294d72); padding: 80px 0; }
.feature-card-dark {
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 16px;
  padding: 32px 24px;
  text-align: center;
  color: #fff;
  height: 100%;
  transition: all .3s;
}
.feature-card-dark:hover {
  background: rgba(230, 51, 18, 0.10);
border: 1px solid rgba(230, 51, 18, 0.10);
  transform: translateY(-5px);
}
.feature-icon {
  width: 60px; height: 60px;
  background: rgba(230,51,18,.15);
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 20px;
  font-size: 1.6rem;
}
.feature-card-dark h5 { font-weight: 700; margin-bottom: 10px; }
.feature-card-dark p { color: rgba(255,255,255,.6); font-size: .9rem; margin: 0; }

/* COURSES */
.courses-section { padding: 90px 0; background: var(--light-bg); }
.course-tabs .nav-pills .nav-link {
  background: #fff;
  color: #666;
  border: 1px solid #ddd;
  border-radius: 50px;
  padding: 10px 24px;
  font-weight: 600;
  margin: 4px;
  font-size: .9rem;
  transition: all .3s;
}
.course-tabs .nav-pills .nav-link.active {
  background: var(--red);
  color: #fff;
  border-color: var(--red);
}
.course-card {
  background: #fff;
  border-radius: 16px;
  padding: 28px;
  box-shadow: 0 4px 20px rgba(0,0,0,.07);
  height: 100%;
  border-top: 4px solid var(--red);
  transition: transform .3s;
}
.course-card:hover { transform: translateY(-4px); }
.course-card h5 { font-weight: 700; color: var(--dark); margin-bottom: 6px; }
.duration-badge {
  background: var(--red);
  color: #fff;
  font-size: .75rem;
  font-weight: 700;
  padding: 4px 12px;
  border-radius: 50px;
  display: inline-block;
  margin-bottom: 14px;
}
.course-topics { list-style: none; padding: 0; margin: 0; }
.course-topics li { font-size: .88rem; color: #555; margin-bottom: 5px; }
.course-topics li::before { content: '✓ '; color: var(--red); font-weight: 700; }
.sub-heading { font-size: .85rem; font-weight: 700; color: var(--dark); margin: 12px 0 8px; }
.note-small { font-size: .8rem; color: #999; margin-top: 12px; margin-bottom: 0; }

/* TABLES */
.table-card {
  background: #fff;
  border-radius: 16px;
  padding: 28px;
  box-shadow: 0 4px 20px rgba(0,0,0,.07);
}
.table-card thead th { background: var(--dark); color: #fff; font-weight: 700; border: none; }
.table-card tbody td { vertical-align: middle; border-color: #f0f0f0; font-size: .9rem; }
.table-card tbody tr:hover td { background: #fff5f4; }
.degree-head th { background: var(--red) !important; }
.fee-note-box {
  background: #fff8f7;
  border-left: 3px solid var(--red);
  padding: 16px;
  border-radius: 8px;
  margin-top: 16px;
  font-size: .85rem;
  color: #555;
}

/* O LEVEL */
.o-level-card {
  background: linear-gradient(135deg, #357abf, #294d72);
  color: #fff;
  border-radius: 20px;
  padding: 36px;
}
.o-level-card h4 { color: var(--gold); font-weight: 800; margin-bottom: 20px; }
.module-row {
  background: rgba(255,255,255,.07);
  border-radius: 10px;
  padding: 12px 18px;
  margin-bottom: 10px;
}
.module-code { color: var(--gold); font-weight: 700; font-size: .85rem; }
.module-name { font-size: .88rem; color: rgba(255,255,255,.85); }
.o-info-box {
  background: rgba(255,255,255,.08);
  border-radius: 12px;
  padding: 24px;
}
.o-info-box ul { color: rgba(255,255,255,.8); font-size: .9rem; padding-left: 16px; line-height: 2; }

/* BATCH TIMING */
.timing-section { background: linear-gradient(135deg, #357abf, #294d72); padding: 80px 0; }
.timing-card {
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 16px;
  padding: 32px;
  color: #fff;
}
.timing-card h4 { color: var(--gold); font-weight: 800; margin-bottom: 20px; text-align: center; }
.time-slot {
  display: flex;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid rgba(255,255,255,.08);
  font-size: .9rem;
}
.time-slot:last-child { border: none; }
.time-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--red); margin-right: 14px; flex-shrink: 0; }

/* DIRECTOR */
.director-section-new { padding: 90px 0; background: #fff; }
.director-photo-wrap { position: relative; }
.director-photo-wrap img {
  border-radius: 20px;
  width: 100%;
  max-height: 480px;
  object-fit: cover;
  box-shadow: 20px 20px 0 var(--red);
}
.director-label { color: var(--red); font-weight: 700; font-size: .85rem; text-transform: uppercase; letter-spacing: 2px; }
.director-section-new h2 { font-size: 2.2rem; font-weight: 800; margin: 12px 0 24px; }
.director-section-new p.dir-para { color: #666; line-height: 1.9; margin-bottom: 12px; }
.signature { border-top: 2px solid #eee; padding-top: 20px; margin-top: 20px; }
.signature h5 { font-weight: 800; margin-bottom: 4px; }
.signature .sig-title { color: var(--red); font-weight: 700; font-size: 1.1rem; margin: 0; }

/* CONTACT */
.contact-section { padding: 90px 0; background: var(--light-bg); }
.contact-card-dark {
  background: linear-gradient(135deg, #357abf, #294d72);
  color: #fff;
  border-radius: 20px;
  padding: 40px;
  height: 100%;
}
.contact-card-dark h4 { color: var(--gold); font-weight: 800; margin-bottom: 24px; }
.contact-item { display: flex; gap: 14px; margin-bottom: 20px; align-items: flex-start; }
.contact-icon {
  width: 42px; height: 42px;
  background: rgba(230,51,18,.2);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem;
  flex-shrink: 0;
}
.contact-item p { margin: 0; color: rgba(255,255,255,.8); font-size: .95rem; line-height: 1.7; }
.contact-item strong { display: block; color: #fff; font-size: .8rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
.info-card-white {
  background: #fff;
  border-radius: 20px;
  padding: 36px;
  box-shadow: 0 8px 30px rgba(0,0,0,.08);
}
.info-card-white h4 { font-weight: 800; color: var(--dark); margin-bottom: 20px; }
.cert-row { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 20px; }
.cert-tag {
  background: #fff3cd;
  border: 1px solid #ffc107;
  color: #856404;
  font-size: .8rem;
  font-weight: 700;
  padding: 5px 14px;
  border-radius: 8px;
}
.admission-note {
  background: #fff5f4;
  border-radius: 12px;
  padding: 20px;
  margin-top: 20px;
  font-size: .88rem;
  color: #555;
}

/* CTA */
.cta-section-new {
  background: linear-gradient(135deg, var(--red), #c72a0e);
  padding: 80px 0;
  text-align: center;
}
.cta-section-new h2 { color: #fff; font-size: 2.6rem; font-weight: 800; }
.cta-section-new p { color: rgba(255,255,255,.85); font-size: 1.1rem; margin: 12px 0 32px; }
.btn-cta-white {
  background: #fff;
  color: var(--red);
  font-weight: 800;
  padding: 14px 40px;
  border-radius: 50px;
  font-size: 1.05rem;
  text-decoration: none;
  display: inline-block;
  margin: 6px;
  transition: all .3s;
}
.btn-cta-white:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,.25); color: var(--red); }
.btn-cta-outline-white {
  background: transparent;
  color: #fff;
  border: 2px solid rgba(255,255,255,.6);
  font-weight: 700;
  padding: 14px 40px;
  border-radius: 50px;
  font-size: 1.05rem;
  text-decoration: none;
  display: inline-block;
  margin: 6px;
  transition: all .3s;
}
.btn-cta-outline-white:hover { border-color: #fff; color: #fff; }

/* RESPONSIVE */
@media(max-width:991px) {
  .hero-section-new h1 { font-size: 2.4rem; }
  .hero-stats { gap: 24px; }
  .director-photo-wrap img { box-shadow: 10px 10px 0 var(--red); }
}
@media(max-width:576px) {
  .hero-section-new h1 { font-size: 2rem; }
  .hero-stats { gap: 16px; }
  .stat-num { font-size: 1.5rem; }
  .section-title h2 { font-size: 1.8rem; }
  .cta-section-new h2 { font-size: 1.8rem; }
  .o-level-card { padding: 24px; }
}
</style>

